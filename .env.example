# Supabase (becarecompliant project ONLY, never joincarenow or carer-academy)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never NEXT_PUBLIC_. Used from Phase 1: audit log writes, invite
# provisioning, and invite acceptance all go through the service-role client.
SUPABASE_SERVICE_ROLE_KEY=

# Absolute base URL of the app. Used for invite email links and auth redirects.
# Production: https://www.becarecompliant.com
NEXT_PUBLIC_SITE_URL=

# Resend (Phase 1: branded invite emails). If unset, invites are still recorded
# but the email silently no-ops and the UI shows "email not sent".
# From address must be on a verified domain: mail.becarecompliant.com
RESEND_API_KEY=
RESEND_FROM="Be Care Compliant <no-reply@mail.becarecompliant.com>"

# Anthropic (Absence: AI policy parsing). Fails closed with a clear message if
# unset. Usage is metered per company into usage_events (Phase 6).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Phase 6: Vercel Cron auth. The daily digest cron fails CLOSED in production
# when this is missing. Vercel sends it as "Authorization: Bearer <value>"
# automatically once the env var exists in the project.
CRON_SECRET=

# Phase 6: Twilio SMS (overdue escalation, opt-in per company). If unset, SMS
# silently no-ops (skippedReason surfaced) and the Notifications settings page
# shows "SMS not configured". Every send is metered into usage_events.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The sending number in E.164, e.g. +447700900123
TWILIO_FROM=

# Phase 7: Stripe billing. Server-only, NEVER NEXT_PUBLIC_. If STRIPE_SECRET_KEY
# is unset the Billing page shows "billing not configured" and Checkout/Portal
# actions fail visibly rather than 500. Use TEST keys (sk_test_...) until the
# whole loop is verified, then switch to live. The webhook secret (whsec_...)
# is the endpoint's signing secret from the Stripe dashboard; the webhook fails
# CLOSED in production when it is missing.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: pin the Stripe API version. Leave blank to use the SDK default.
STRIPE_API_VERSION=

# Stripe Price IDs (created in the Stripe dashboard, test mode first). The base
# price is the flat monthly tier fee; STRIPE_PRICE_SEAT is the single £5/user
# per-seat price shared by all subscription tiers (quantity = extra users).
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PRICE_SEAT=

# Diamond usage rates (pence per unit): SMS per segment, AI per token. Optional.
# If unset, the monthly Diamond usage cron bills the metered cost already
# recorded on each event (pass through of our cost). The customer facing rate is
# an OPEN decision: set these once agreed, no code change needed.
STRIPE_DIAMOND_SMS_PENCE=
STRIPE_DIAMOND_AI_PENCE=
